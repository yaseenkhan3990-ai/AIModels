<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Content Creation Studio</title>
  <style>
    :root {
      --bg:
        radial-gradient(circle at 10% 10%, rgba(255, 140, 92, 0.22), transparent 24%),
        radial-gradient(circle at 86% 12%, rgba(32, 201, 151, 0.18), transparent 20%),
        radial-gradient(circle at 80% 78%, rgba(26, 115, 232, 0.16), transparent 24%),
        linear-gradient(155deg, #fff6ee 0%, #f3fbff 48%, #eefaf4 100%);
      --surface: rgba(255, 255, 255, 0.78);
      --surface-strong: rgba(255, 255, 255, 0.92);
      --border: rgba(18, 43, 62, 0.1);
      --text: #173042;
      --muted: #617587;
      --primary: #f16d43;
      --primary-dark: #cb532b;
      --secondary: #1a73e8;
      --success: #179b72;
      --shadow: 0 24px 64px rgba(36, 60, 82, 0.14);
      --radius: 28px;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      color: var(--text);
      background: var(--bg);
    }

    .page {
      width: min(1280px, calc(100% - 28px));
      margin: 0 auto;
      padding: 22px 0 34px;
      display: grid;
      gap: 22px;
    }

    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      backdrop-filter: blur(12px);
    }

    .hero {
      padding: 32px;
      display: grid;
      grid-template-columns: 1.12fr 0.88fr;
      gap: 22px;
      align-items: stretch;
    }

    .eyebrow {
      display: inline-flex;
      margin: 0 0 16px;
      padding: 8px 14px;
      border-radius: 999px;
      background: rgba(241, 109, 67, 0.12);
      color: var(--primary-dark);
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    h1,
    h2,
    h3,
    h4,
    p {
      margin: 0;
    }

    h1 {
      font-size: clamp(2.3rem, 4vw, 4.4rem);
      line-height: 0.95;
      letter-spacing: -0.04em;
    }

    .subtitle {
      margin-top: 16px;
      color: var(--muted);
      line-height: 1.72;
      font-size: 1rem;
    }

    .heroPanel {
      padding: 22px;
      border-radius: 24px;
      background: var(--surface-strong);
      border: 1px solid rgba(18, 43, 62, 0.08);
      display: grid;
      gap: 14px;
      align-content: start;
    }

    .heroPanel strong {
      display: block;
      margin-bottom: 6px;
      font-size: 0.98rem;
    }

    .heroPanel p {
      color: var(--muted);
      line-height: 1.65;
    }

    .workspace {
      display: grid;
      grid-template-columns: 50% 1fr;
      gap: 22px;
      align-items: start;
    }

    .sidebar,
    .results {
      padding: 24px;
    }

    .formGrid {
      display: grid;
      gap: 14px;
    }

    label {
      display: grid;
      gap: 8px;
      font-size: 0.95rem;
      color: var(--muted);
    }

    input,
    textarea,
    select,
    button {
      width: 100%;
      font: inherit;
      border-radius: 18px;
    }

    input,
    textarea,
    select {
      border: 1px solid rgba(22, 48, 66, 0.12);
      background: rgba(255, 255, 255, 0.95);
      color: var(--text);
      padding: 13px 14px;
    }

    textarea {
      resize: vertical;
      min-height: 108px;
      line-height: 1.55;
    }

    .fieldHint {
      font-size: 0.85rem;
      color: var(--muted);
      line-height: 1.5;
    }

    .choiceGrid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .toneOption input {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }

    .toneCard {
      display: grid;
      gap: 6px;
      padding: 14px;
      border-radius: 20px;
      border: 1px solid rgba(22, 48, 66, 0.08);
      background: rgba(255, 255, 255, 0.82);
      transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
      cursor: pointer;
    }

    .toneCard strong {
      color: var(--text);
      font-size: 0.95rem;
    }

    .toneCard span {
      color: var(--muted);
      font-size: 0.84rem;
      line-height: 1.45;
    }

    .toneOption input:checked + .toneCard {
      border-color: rgba(241, 109, 67, 0.45);
      background: rgba(241, 109, 67, 0.12);
      box-shadow: 0 14px 30px rgba(241, 109, 67, 0.12);
      transform: translateY(-1px);
    }

    .toneOption input:focus-visible + .toneCard {
      outline: 2px solid rgba(26, 115, 232, 0.35);
      outline-offset: 2px;
    }

    .checks {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
    }

    .check {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 13px 14px;
      border-radius: 18px;
      border: 1px solid rgba(22, 48, 66, 0.08);
      background: rgba(255, 255, 255, 0.78);
      color: var(--text);
    }

    .check input {
      width: auto;
      margin: 0;
    }

    .mediaFrame {
      border-radius: 24px;
      border: 1px dashed rgba(26, 115, 232, 0.3);
      background:
        radial-gradient(circle at top, rgba(26, 115, 232, 0.08), transparent 36%),
        linear-gradient(145deg, rgba(255, 255, 255, 0.96), rgba(243, 249, 255, 0.9));
      padding: 18px;
      display: grid;
      gap: 12px;
      width: 100%;
    }

    .preview {
      width: 100%;
      aspect-ratio: 16 / 9;
      border-radius: 20px;
      background: #dbe9f7;
      object-fit: cover;
      display: none;
    }

    .preview.active {
      display: block;
    }

    .placeholder {
      aspect-ratio: 16 / 9;
      border-radius: 20px;
      display: grid;
      place-items: center;
      text-align: center;
      padding: 22px;
      color: var(--muted);
      background:
        linear-gradient(135deg, rgba(241, 109, 67, 0.16), rgba(26, 115, 232, 0.14)),
        #f7fbff;
      line-height: 1.6;
    }

    .placeholder.hidden {
      display: none;
    }

    .buttonRow {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }

    button {
      border: none;
      cursor: pointer;
      padding: 14px 18px;
      font-weight: 700;
      transition: transform 0.18s ease, opacity 0.18s ease, background 0.18s ease;
    }

    button:hover:enabled {
      transform: translateY(-2px);
    }

    button:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }

    .primaryBtn {
      background: var(--primary);
      color: #fff;
    }

    .primaryBtn:hover:enabled {
      background: var(--primary-dark);
    }

    .ghostBtn {
      background: rgba(26, 115, 232, 0.1);
      color: var(--secondary);
    }

    .status {
      min-height: 24px;
      color: var(--primary-dark);
      font-weight: 600;
    }

    .resultsHeader {
      display: flex;
      justify-content: space-between;
      gap: 14px;
      align-items: start;
      margin-bottom: 16px;
    }

    .resultsHeader p {
      margin-top: 8px;
      color: var(--muted);
      line-height: 1.6;
    }

    .pill {
      padding: 10px 14px;
      border-radius: 999px;
      background: rgba(23, 155, 114, 0.12);
      color: var(--success);
      font-weight: 700;
      white-space: nowrap;
    }

    .emptyState {
      padding: 26px;
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.72);
      border: 1px dashed rgba(22, 48, 66, 0.12);
      color: var(--muted);
      line-height: 1.7;
    }

    .section {
      margin-top: 18px;
      padding: 20px;
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.74);
      border: 1px solid rgba(22, 48, 66, 0.08);
    }

    .sectionTitle {
      margin-bottom: 14px;
      font-size: 1.08rem;
    }

    .summaryGrid,
    .analysisGrid,
    .metaGrid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }

    .miniCard {
      padding: 16px;
      border-radius: 20px;
      background: var(--surface-strong);
      border: 1px solid rgba(22, 48, 66, 0.08);
      display: grid;
      gap: 8px;
    }

    .miniCard p,
    .platformCard p,
    .transcriptBox {
      color: var(--muted);
      line-height: 1.7;
      white-space: pre-wrap;
    }

    .listChips {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-top: 12px;
    }

    .chip {
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(241, 109, 67, 0.1);
      color: var(--primary-dark);
      font-size: 0.88rem;
      font-weight: 700;
    }

    .mutedChip {
      background: rgba(97, 117, 135, 0.12);
      color: var(--muted);
    }

    .platformGrid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
      margin-top: 18px;
    }

    .platformCard {
      padding: 18px;
      border-radius: 24px;
      background: var(--surface-strong);
      border: 1px solid rgba(22, 48, 66, 0.08);
      display: grid;
      gap: 14px;
      align-content: start;
    }

    .platformCard h3 {
      font-size: 1.08rem;
    }

    .copyBtn {
      background: rgba(26, 115, 232, 0.1);
      color: var(--secondary);
      padding: 12px 14px;
    }

    .fieldBlock {
      display: grid;
      gap: 8px;
    }

    .fieldBlock strong {
      font-size: 0.92rem;
    }

    .textPanel {
      padding: 14px 16px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.88);
      border: 1px solid rgba(22, 48, 66, 0.08);
      color: var(--muted);
      line-height: 1.7;
      white-space: pre-wrap;
    }

    .transcriptBox {
      max-height: 280px;
      overflow: auto;
      padding: 16px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.86);
      border: 1px solid rgba(22, 48, 66, 0.08);
    }

    .codeBox {
      padding: 16px;
      border-radius: 18px;
      background: #173042;
      color: #f3fbff;
      overflow: auto;
      font-size: 0.88rem;
      line-height: 1.6;
      margin: 0;
    }

    @media (max-width: 1080px) {
      .hero,
      .workspace,
      .platformGrid,
      .summaryGrid,
      .analysisGrid,
      .metaGrid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 720px) {
      .page {
        width: min(100% - 18px, 1280px);
      }

      .hero,
      .sidebar,
      .results {
        padding: 20px;
      }

      .choiceGrid,
      .checks {
        grid-template-columns: 1fr;
      }

      .buttonRow {
        flex-direction: column;
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <section class="hero card">
      <div>
        <p class="eyebrow">Content Creation Studio</p>
        <h1>Upload your video. Get AI analysis and upload-ready copy.</h1>
        <p class="subtitle">
          This workflow accepts a video or audio file, transcribes what is said, analyzes the uploaded media,
          and produces a strong social package with descriptions, tags, hashtags, hooks, CTA ideas, and
          per-platform copy for YouTube, Instagram, and Facebook.
        </p>
      </div>

      <div class="heroPanel">
        <div>
          <strong>What you get</strong>
          <p>Content summary, audience hook, visual and spoken highlights, upload description, tags, hashtags, and platform-specific copy blocks you can paste directly.</p>
        </div>
        <div>
          <strong>Best input</strong>
          <p>Clear speech helps the transcript. Adding brand, audience, and goal makes the AI output more useful and more aligned to the social post you want.</p>
        </div>
        <div>
          <strong>Built for posting</strong>
          <p>The generated output is shown as readable cards for humans and as structured JSON if you want to connect this flow to later automation.</p>
        </div>
      </div>
    </section>

    <section class="workspace">
      <aside class="sidebar card">
        <h2>Upload And Configure</h2>
        <p class="subtitle" style="margin-top: 10px;">
          Upload one asset, set the targeting details, and let AI prepare the content package.
        </p>

        <form id="contentForm" class="formGrid">
          <div class="mediaFrame">
            <video id="videoPreview" class="preview" controls></video>
            <div id="previewPlaceholder" class="placeholder">
              Select a video to preview it here before sending it for AI analysis.
            </div>

            <label for="videoInput">
              Video or audio file
              <input id="videoInput" name="video" type="file" accept="video/*,audio/*" required />
            </label>
          </div>

          <div class="buttonRow">
            <button id="generateBtn" class="primaryBtn" type="submit">Analyze Video And Generate Copy</button>
            <button id="resetBtn" class="ghostBtn" type="button">Clear</button>
          </div>

          <p id="statusText" class="status">Upload a file and generate your content package.</p>
        </form>
      </aside>

      <section class="results card">
        <div class="resultsHeader">
          <div>
            <h2>Generated Output</h2>
            <p>AI analysis first, then posting assets you can actually use.</p>
          </div>
          <div id="resultBadge" class="pill">Waiting for input</div>
        </div>

        <div id="emptyState" class="emptyState">
          Your generated content package will appear here after you upload a file and click generate.
        </div>

        <div id="resultsContent" hidden>
          <section class="section">
            <h3 class="sectionTitle">AI Media Analysis</h3>
            <div class="analysisGrid">
              <div class="miniCard">
                <strong>Content Summary</strong>
                <p id="analysisSummary"></p>
              </div>
              <div class="miniCard">
                <strong>Best Audience Hook</strong>
                <p id="analysisHook"></p>
              </div>
              <div class="miniCard">
                <strong>Spoken Highlights</strong>
                <p id="analysisSpoken"></p>
              </div>
              <div class="miniCard">
                <strong>Visual Highlights</strong>
                <p id="analysisVisual"></p>
              </div>
            </div>
            <div class="miniCard" style="margin-top: 14px;">
              <strong>Why This Can Perform</strong>
              <p id="analysisPerformance"></p>
            </div>
          </section>

          <section class="section">
            <h3 class="sectionTitle">Master Upload Package</h3>
            <div class="summaryGrid">
              <div class="miniCard">
                <strong>Content Angle</strong>
                <p id="contentAngle"></p>
              </div>
              <div class="miniCard">
                <strong>Audience Fit</strong>
                <p id="audienceFit"></p>
              </div>
              <div class="miniCard">
                <strong>Headline</strong>
                <p id="masterHeadline"></p>
              </div>
              <div class="miniCard">
                <strong>Summary</strong>
                <p id="masterSummary"></p>
              </div>
            </div>
            <div class="miniCard" style="margin-top: 14px;">
              <strong>Description</strong>
              <p id="masterDescription"></p>
            </div>
            <div class="metaGrid" style="margin-top: 14px;">
              <div class="miniCard">
                <strong>Posting Notes</strong>
                <p id="postingNotes"></p>
              </div>
              <div class="miniCard">
                <strong>Recommended Platform Order</strong>
                <p id="platformOrder"></p>
              </div>
              <div class="miniCard">
                <strong>CTA Options</strong>
                <p id="ctaOptions"></p>
              </div>
            </div>
            <div class="metaGrid" style="margin-top: 14px;">
              <div class="miniCard">
                <strong>Keywords</strong>
                <div id="keywordText" class="textPanel"></div>
              </div>
              <div class="miniCard">
                <strong>Tags</strong>
                <div id="tagText" class="textPanel"></div>
              </div>
            </div>
            <div class="miniCard" style="margin-top: 14px;">
              <strong>Hashtags</strong>
              <div id="hashtagText" class="textPanel"></div>
            </div>
          </section>

          <section class="section">
            <h3 class="sectionTitle">Platform Packages</h3>
            <div class="platformGrid">
              <article class="platformCard">
                <h3>YouTube</h3>
                <div class="fieldBlock">
                  <strong>Title</strong>
                  <p id="youtubeTitle"></p>
                </div>
                <div class="fieldBlock">
                  <strong>Alternative Titles</strong>
                  <p id="youtubeAltTitles"></p>
                </div>
                <div class="fieldBlock">
                  <strong>Description</strong>
                  <p id="youtubeDescription"></p>
                </div>
                <div class="fieldBlock">
                  <strong>Tags</strong>
                  <div id="youtubeTags" class="textPanel"></div>
                </div>
                <div class="fieldBlock">
                  <strong>Hashtags</strong>
                  <div id="youtubeHashtags" class="textPanel"></div>
                </div>
                <div class="fieldBlock">
                  <strong>Thumbnail Text Ideas</strong>
                  <p id="youtubeThumbnails"></p>
                </div>
                <div class="fieldBlock">
                  <strong>Chapter Ideas</strong>
                  <p id="youtubeChapters"></p>
                </div>
                <button class="copyBtn" type="button" data-copy-target="youtube">Copy YouTube Package</button>
              </article>

              <article class="platformCard">
                <h3>Instagram</h3>
                <div class="fieldBlock">
                  <strong>Hook</strong>
                  <p id="instagramHook"></p>
                </div>
                <div class="fieldBlock">
                  <strong>Caption</strong>
                  <p id="instagramCaption"></p>
                </div>
                <div class="fieldBlock">
                  <strong>Story Text</strong>
                  <p id="instagramStory"></p>
                </div>
                <div class="fieldBlock">
                  <strong>Reel Cover Text</strong>
                  <p id="instagramCover"></p>
                </div>
                <div class="fieldBlock">
                  <strong>First Comment</strong>
                  <p id="instagramFirstComment"></p>
                </div>
                <div class="fieldBlock">
                  <strong>Hashtags</strong>
                  <div id="instagramHashtags" class="textPanel"></div>
                </div>
                <button class="copyBtn" type="button" data-copy-target="instagram">Copy Instagram Package</button>
              </article>

              <article class="platformCard">
                <h3>Facebook</h3>
                <div class="fieldBlock">
                  <strong>Hook</strong>
                  <p id="facebookHook"></p>
                </div>
                <div class="fieldBlock">
                  <strong>Caption</strong>
                  <p id="facebookCaption"></p>
                </div>
                <div class="fieldBlock">
                  <strong>Comment Prompt</strong>
                  <p id="facebookCommentPrompt"></p>
                </div>
                <div class="fieldBlock">
                  <strong>Share Text</strong>
                  <p id="facebookShareText"></p>
                </div>
                <div class="fieldBlock">
                  <strong>Hashtags</strong>
                  <div id="facebookHashtags" class="textPanel"></div>
                </div>
                <button class="copyBtn" type="button" data-copy-target="facebook">Copy Facebook Package</button>
              </article>
            </div>
          </section>

          <section class="section">
            <h3 class="sectionTitle">Transcript</h3>
            <div id="transcriptBox" class="transcriptBox"></div>
          </section>

          <section class="section">
            <h3 class="sectionTitle">Structured JSON</h3>
            <pre id="jsonOutput" class="codeBox"></pre>
          </section>
        </div>
      </section>
    </section>
  </main>

  <script src="/contentCreation.js"></script>
</body>
</html>
