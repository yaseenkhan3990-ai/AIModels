<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>VoiceBridge Assistant</title>
  <style>
    :root {
      --bg:
        radial-gradient(circle at top left, rgba(255, 110, 64, 0.20), transparent 28%),
        radial-gradient(circle at top right, rgba(0, 191, 165, 0.20), transparent 24%),
        linear-gradient(155deg, #fff6ec 0%, #ffe0d2 38%, #d9f6f0 100%);
      --panel: rgba(255, 252, 248, 0.78);
      --panel-border: rgba(20, 82, 74, 0.12);
      --text: #19343a;
      --muted: #5f777d;
      --accent: #ff6e40;
      --accent-dark: #dc5530;
      --accent-soft: #fff0ea;
      --secondary-accent: #00bfa5;
      --shadow: 0 24px 70px rgba(54, 84, 88, 0.16);
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      color: var(--text);
      background: var(--bg);
      display: grid;
      place-items: center;
      padding: 24px;
    }

    .shell {
      width: min(1080px, 100%);
      background: var(--panel);
      border: 1px solid var(--panel-border);
      border-radius: 32px;
      box-shadow: var(--shadow);
      backdrop-filter: blur(14px);
      overflow: hidden;
    }

    .hero {
      padding: 34px 34px 18px;
      text-align: center;
    }

    .eyebrow {
      margin: 0 0 10px;
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
    }

    h1 {
      margin: 0;
      font-size: clamp(2rem, 4vw, 3.4rem);
      line-height: 0.95;
    }

    .subtitle {
      max-width: 720px;
      margin: 14px auto 0;
      font-size: 1rem;
      line-height: 1.6;
      color: var(--muted);
    }

    .grid {
      display: grid;
      grid-template-columns: 1.1fr 1fr;
      gap: 20px;
      padding: 0 34px 34px;
    }

    .panel {
      background: rgba(255, 255, 255, 0.78);
      border: 1px solid rgba(20, 82, 74, 0.09);
      border-radius: 24px;
      padding: 22px;
    }

    .panel h2 {
      margin: 0 0 14px;
      font-size: 1.05rem;
    }

    .controls {
      display: grid;
      gap: 14px;
    }

    .mainPanel {
      grid-column: 1 / -1;
      background:
        radial-gradient(circle at top, rgba(255, 255, 255, 0.98), rgba(255, 248, 243, 0.96)),
        linear-gradient(135deg, rgba(255, 110, 64, 0.10), rgba(0, 191, 165, 0.10));
    }

    .centerStage {
      display: grid;
      gap: 18px;
      justify-items: center;
      text-align: center;
    }

    .avatarWrap {
      position: relative;
      width: 184px;
      height: 184px;
      display: grid;
      place-items: center;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255, 255, 255, 0.98), rgba(255, 236, 228, 0.95));
      box-shadow: inset 0 0 0 10px rgba(255, 255, 255, 0.55);
      overflow: hidden;
    }

    .avatarAura {
      position: absolute;
      font-size: 2rem;
      top: 14px;
      right: 18px;
      color: var(--secondary-accent);
      animation: orbit 2.2s ease-in-out infinite;
    }

    .assistantFace {
      font-size: 5.8rem;
      line-height: 1;
      transform-origin: center;
      animation: bob 2.8s ease-in-out infinite;
      user-select: none;
    }

    .assistantFace[data-state="listening"] {
      animation: pulse 0.9s ease-in-out infinite;
    }

    .assistantFace[data-state="thinking"] {
      animation: bob 1.2s ease-in-out infinite;
    }

    .assistantFace[data-state="speaking"] {
      animation: chatter 0.5s ease-in-out infinite;
    }

    .assistantMood {
      margin: 0;
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--accent-dark);
    }

    .assistantHint {
      margin: 0;
      max-width: 580px;
      color: var(--muted);
      line-height: 1.6;
    }

    .quickConfig {
      width: 100%;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
      margin-top: 6px;
    }

    label {
      display: grid;
      gap: 8px;
      font-size: 0.95rem;
      color: var(--muted);
    }

    select,
    input,
    textarea,
    button,
    audio {
      width: 100%;
      border-radius: 16px;
      border: 1px solid rgba(255, 110, 64, 0.14);
      font: inherit;
    }

    select,
    input,
    textarea {
      padding: 12px 14px;
      background: #fff;
      color: var(--text);
    }

    textarea {
      min-height: 140px;
      resize: vertical;
    }

    .buttonRow {
      display: flex;
      gap: 12px;
      width: 100%;
    }

    button {
      padding: 14px 18px;
      cursor: pointer;
      border: none;
      color: white;
      background: var(--accent);
      font-weight: 700;
      transition: transform 0.15s ease, background 0.15s ease, opacity 0.15s ease;
    }

    button:hover:enabled {
      transform: translateY(-1px);
      background: var(--accent-dark);
    }

    button:disabled {
      opacity: 0.55;
      cursor: not-allowed;
    }

    .ghost {
      background: var(--accent-soft);
      color: var(--accent-dark);
    }

    .status {
      margin: 0;
      min-height: 24px;
      color: var(--accent-dark);
      font-weight: 600;
    }

    .composer {
      display: grid;
      gap: 14px;
      width: 100%;
      max-width: 760px;
    }

    .sendRow {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 12px;
      align-items: end;
    }

    .transcriptGrid {
      display: grid;
      grid-column: 1 / -1;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 20px;
      align-items: stretch;
    }

    .output {
      min-height: 132px;
      margin: 0;
      padding: 16px;
      background: rgba(255, 255, 255, 0.88);
      border-radius: 16px;
      border: 1px solid rgba(54, 94, 112, 0.08);
      line-height: 1.6;
      white-space: pre-wrap;
    }

    .meta {
      margin-top: 14px;
      font-size: 0.9rem;
      line-height: 1.6;
      color: var(--muted);
    }

    @keyframes bob {
      0%, 100% { transform: translateY(0) scale(1); }
      50% { transform: translateY(-6px) scale(1.03); }
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); filter: drop-shadow(0 0 0 rgba(124, 77, 255, 0)); }
      50% { transform: scale(1.12); filter: drop-shadow(0 0 18px rgba(0, 191, 165, 0.30)); }
    }

    @keyframes chatter {
      0%, 100% { transform: translateY(0) rotate(0deg) scale(1); }
      25% { transform: translateY(-3px) rotate(-4deg) scale(1.04); }
      75% { transform: translateY(-1px) rotate(4deg) scale(1.04); }
    }

    @keyframes orbit {
      0%, 100% { transform: translateY(0) rotate(0deg); }
      50% { transform: translateY(-5px) rotate(12deg); }
    }

    @media (max-width: 640px) {
      .hero,
      .grid {
        padding-left: 20px;
        padding-right: 20px;
      }

      .grid,
      .quickConfig,
      .transcriptGrid,
      .sendRow {
        grid-template-columns: 1fr;
      }

      .buttonRow {
        flex-direction: column;
      }

      .avatarWrap {
        width: 156px;
        height: 156px;
      }

      .assistantFace {
        font-size: 5rem;
      }
    }

    .openBtn{
    padding: 14px 18px;
    cursor: pointer;
    border: none;
    color: white;
    background: var(--accent);
    font-weight: 700;
    transition: transform 0.15s ease, background 0.15s ease, opacity 0.15s ease;
    border-radius: 30px;
    width: 50%;
    }
    .openBtn.active{
      transform: translateX(100%);
    }  
    .closeBtn{
        width: 100%;
        background: var(--accent-soft);
        color: var(--accent-dark);
        border-radius: 30px;
    }

  </style>
</head>
<body>
  <main class="shell">
    <section class="hero">
      <p class="eyebrow">Voice Translation Assistant</p>
      <h1>Speak once. Get a spoken in any language.</h1>
      <p class="subtitle">
        Record your voice, choose the language you want, and the assistant will transcribe,
        translate or answer, then speak back naturally. Your API key stays on the server.
      </p>
    </section>

    <section class="grid">
      <div class="panel mainPanel">
        <div class="centerStage">
          <div class="avatarWrap">
            <span id="assistantAura" class="avatarAura" aria-hidden="true">✦</span>
            <div id="assistantFace" class="assistantFace" data-state="idle" aria-hidden="true">🙂</div>
          </div>
          <p id="assistantMood" class="assistantMood">Ready to help</p>
          <p class="assistantHint">
            Speak or type, choose the language you want, and the assistant will answer back with voice.
          </p>

          <div class="quickConfig">
            <label for="languageSelect">
              Language
              <select id="languageSelect">
                <% languages.forEach((language) => { %>
                  <option value="<%= language %>" <%= language === defaultLanguage ? "selected" : "" %>>
                    <%= language %>
                  </option>
                <% }) %>
              </select>
            </label>

            <label for="voiceSelect">
              Voice
              <select id="voiceSelect">
                <% voices.forEach((voice) => { %>
                  <option value="<%= voice %>" <%= voice === defaultVoice ? "selected" : "" %>>
                    <%= voice %>
                  </option>
                <% }) %>
              </select>
            </label>

            <label for="assistantMode">
              Style
              <input
                id="assistantMode"
                type="text"
                value="Helpful and easy to understand"
                placeholder="Friendly, formal, teacher..."
              />
            </label>
          </div>

          <div class="composer">
            <div class="buttonRow closeBtn">
              <div id="startBtn" class="openBtn">Start speaking</div>
            </div>

            <div class="sendRow">
              <label for="textInput">
                <textarea
                  id="textInput"
                  placeholder="Ask anything or paste text to translate..."
                ></textarea>
              </label>
              <button id="sendTextBtn" type="button">Send text</button>
            </div>

            <p id="statusText" class="status"></p>
            <audio id="audioPlayer" controls></audio>

            <p class="meta">
                Tip:press `Ctrl + Enter` in the text box for quick send.
            </p>
            
          </div>
        </div>
      </div>

      <div class="transcriptGrid">
        <div class="panel">
          <h2>What You Said</h2>
          <p id="transcriptOutput" class="output">Your transcript will appear here after recording.</p>
        </div>

        <div class="panel">
          <h2>Assistant Reply</h2>
          <p id="responseOutput" class="output">The translated or answered response will appear here.</p>
        </div>
      </div>
    </section>
  </main>

  <script src="/script.js"></script>
</body>
</html>
